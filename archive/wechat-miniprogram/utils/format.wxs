// 格式化工具函数 - 显示真实相似度百分比
var formatScore = function(val) {
  if (!val) return '0.0';

  // 真实相似度（0.0-1.0）
  var realScore = parseFloat(val);

  // 显示真实百分比（相似度 × 100）
  var displayPercent = realScore * 100;

  // 限制在0-100之间
  if (displayPercent < 0) displayPercent = 0;
  if (displayPercent > 100) displayPercent = 100;

  return displayPercent.toFixed(1);
}

// 格式化时间（秒 -> MM:SS）
var formatTime = function(seconds) {
  if (!seconds || seconds <= 0) return '00:00';

  var mins = Math.floor(seconds / 60);
  var secs = Math.floor(seconds % 60);

  return mins.toString().padStart(2, '0') + ':' + secs.toString().padStart(2, '0');
}

// 格式化数字，保留指定小数位数
var formatNumber = function(num, decimals) {
  if (num === undefined || num === null) return '0';
  if (decimals === undefined) decimals = 1;

  return parseFloat(num).toFixed(decimals);
}

// 安全获取对象属性，提供默认值
var safeGet = function(obj, prop, defaultValue) {
  if (!obj || obj[prop] === undefined || obj[prop] === null) {
    return defaultValue !== undefined ? defaultValue : '';
  }
  return obj[prop];
}

// 去除字符串两端空格
var trim = function(str) {
  if (!str) return '';
  return str.toString().trim();
}

// 检查字符串是否为空（去除空格后）
var isEmpty = function(str) {
  if (!str) return true;
  return trim(str).length === 0;
}

module.exports = {
  formatScore: formatScore,
  formatTime: formatTime,
  formatNumber: formatNumber,
  safeGet: safeGet,
  trim: trim,
  isEmpty: isEmpty
}