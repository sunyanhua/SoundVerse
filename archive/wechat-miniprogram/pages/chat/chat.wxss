/* 聊天页面样式 */
.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  display: flex;
  flex-direction: column;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 32rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

/* 消息项 */
.message-item {
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
}

/* 用户消息（靠右） */
.user-message {
  align-items: flex-end;
}

/* 助手消息（靠左） */
.assistant-message {
  align-items: flex-start;
}

/* 消息气泡 */
.message-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  position: relative;
  word-break: break-word;
}

/* 用户消息气泡样式 */
.user-message .message-bubble {
  background-color: #07c160;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

/* 助手消息气泡样式 */
.assistant-message .message-bubble {
  background-color: #fff;
  color: #333;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 消息内容 */
.message-content {
  font-size: 32rpx;
  line-height: 1.5;
}

/* 消息时间 */
.message-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  padding: 0 8rpx;
}

.user-message .message-time {
  text-align: right;
}

.assistant-message .message-time {
  text-align: left;
}

/* 音频容器 */
.audio-container {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
}

.user-message .audio-container {
  border-top-color: rgba(255, 255, 255, 0.3);
}

/* 音频播放器 */
.audio-player {
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
}

.assistant-message .audio-player {
  background-color: #f0f9ff;
}

/* 音频控制 */
.audio-controls {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 播放按钮 */
.play-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #07c160;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.play-btn::after {
  border: none;
}

.play-btn.playing {
  background-color: #ff6b6b;
}

.play-btn text {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}

/* 音频文本 */
.audio-text {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

/* 音频进度条 */
.audio-progress {
  margin-top: 12rpx;
}

.progress-text {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 4rpx;
}

/* 音频信息 */
.audio-info {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.audio-source-line,
.similarity-score-line {
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
}

.audio-source-label,
.similarity-score-label {
  color: #999;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.audio-source-value {
  color: #fa8c16;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.similarity-score-value {
  color: #52c41a;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 旧的样式保持兼容，但可能不再使用 */
.audio-duration,
.audio-source,
.similarity-score {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.audio-source {
  color: #fa8c16;
  font-weight: 500;
}

.similarity-score {
  color: #52c41a;
  font-weight: 500;
}

/* 输入容器 */
.input-container {
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  padding: 20rpx 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 输入包装器 */
.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 消息输入框 */
.message-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 32rpx;
  font-size: 32rpx;
  color: #333;
  height: 80rpx;
  box-sizing: border-box;
}

.message-input::placeholder {
  color: #999;
}

/* 发送按钮 */
.send-btn {
  width: 120rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #e0e0e0;
  color: #999;
  border: none;
  padding: 0;
  font-size: 32rpx;
  transition: all 0.2s;
}

.send-btn::after {
  border: none;
}

.send-btn.active {
  background-color: #07c160;
  color: #fff;
}

.send-btn[disabled] {
  background-color: #e0e0e0 !important;
  color: #999 !important;
  opacity: 1;
}

/* 语音输入 */
.voice-input {
  margin-top: 16rpx;
  display: block; /* 启用语音输入 */
}

.record-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #f5f5f5;
  color: #666;
  border: none;
  padding: 0;
  font-size: 32rpx;
  transition: all 0.2s;
}

.record-btn::after {
  border: none;
}

.record-btn.recording {
  background-color: #ff6b6b;
  color: #fff;
}

.record-btn[disabled] {
  opacity: 0.5;
  background-color: #e0e0e0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  display: block;
  font-size: 36rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-hint {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

/* 快捷问题 */
.quick-questions {
  text-align: left;
}

.quick-title {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 20rpx;
  text-align: center;
}

.quick-question {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e0e0e0;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
}

.quick-question:active {
  background-color: #f5f5f5;
  transform: scale(0.98);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 28rpx;
}

/* 响应式调整 */
@media screen and (max-width: 360px) {
  .message-bubble {
    max-width: 80%;
  }

  .message-content {
    font-size: 30rpx;
  }
}

/* 快捷问题容器（始终显示） */
.quick-questions-container {
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  border-bottom: 1rpx solid #e0e0e0;
  padding: 32rpx;
  margin-top: 20rpx;
}

/* 空状态下的快捷问题容器 */
.empty-state .quick-questions-container {
  background-color: transparent;
  border-top: none;
  border-bottom: none;
  padding: 0;
  margin-top: 0;
}

/* 空状态下的快捷问题滚动容器 */
.empty-state .quick-questions-scroll {
  margin-top: 20rpx;
}

.quick-questions-scroll {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-bottom: 8rpx;
  -webkit-overflow-scrolling: touch;
}

.quick-question-item {
  background-color: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  border: 1rpx solid #e0e0e0;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  transition: all 0.2s;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 0 0 auto;
  min-width: 180rpx;
}

.quick-question-item:active {
  background-color: #e8f4ff;
  transform: scale(0.98);
  border-color: #1890ff;
}

/* PC端满屏展示样式 */
@media (min-width: 768px) {
  /* 页面容器调整 */
  .page-container {
    max-width: 1200rpx;
    margin: 0 auto;
  }

  /* 消息气泡增加最大宽度 */
  .message-bubble {
    max-width: 60%;
  }

  /* 消息内容字体调整 */
  .message-content {
    font-size: 36rpx;
  }

  /* 输入容器调整 */
  .input-container {
    padding: 32rpx 40rpx;
  }

  /* 消息输入框调整 */
  .message-input {
    font-size: 36rpx;
    height: 96rpx;
    padding: 24rpx 40rpx;
  }

  /* 发送按钮调整 */
  .send-btn {
    width: 160rpx;
    height: 96rpx;
    font-size: 36rpx;
  }

  /* 快捷问题容器调整 */
  .quick-questions-container {
    padding: 40rpx;
  }

  .quick-questions-scroll {
    gap: 24rpx;
    padding-bottom: 12rpx;
  }

  .quick-question-item {
    padding: 24rpx;
    font-size: 30rpx;
    min-width: 200rpx;
  }

  /* 音频播放器调整 */
  .audio-player {
    padding: 24rpx;
  }
}