<!-- 上传页面 -->
<view class="upload-page">
  <view class="header">
    <text class="title">音频上传</text>
    <text class="subtitle">上传您的音频文件，AI将为您处理和分析</text>
  </view>

  <view class="upload-area" bindtap="chooseFile">
    <view class="upload-icon">📁</view>
    <text class="upload-text">点击选择音频文件</text>
    <text class="upload-hint">支持 mp3, wav, m4a, ogg, flac 格式</text>
  </view>

  <view class="file-list" wx:if="{{ fileList.length > 0 }}">
    <view class="section-title">已选择文件</view>
    <view class="file-item" wx:for="{{fileList}}" wx:key="index">
      <text class="file-name">{{item.name}}</text>
      <text class="file-size">{{item.size}}</text>
    </view>
  </view>

  <view class="action-buttons">
    <button class="upload-btn" type="primary" bindtap="uploadFile" disabled="{{ fileList.length === 0 }}">开始上传</button>
    <button class="cancel-btn" bindtap="cancelUpload">取消</button>
  </view>

  <view class="tips">
    <text class="tip-title">上传须知：</text>
    <text class="tip-item">1. 文件大小不超过 100MB</text>
    <text class="tip-item">2. 音频时长建议在 1-300 秒之间</text>
    <text class="tip-item">3. 上传后AI将自动分割和识别</text>
    <text class="tip-item">4. 处理完成后可在聊天中使用</text>
  </view>
</view>