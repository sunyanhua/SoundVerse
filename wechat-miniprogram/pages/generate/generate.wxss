/* 生成页面样式 */
.generate-page {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.header {
  margin-bottom: 40rpx;
  color: white;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
}

.input-area {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.prompt-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

.placeholder {
  color: #999;
}

.input-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.char-count {
  font-size: 26rpx;
  color: #666;
}

.generate-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.generate-btn, .example-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.generate-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.generate-btn[disabled] {
  opacity: 0.6;
}

.example-btn {
  background: white;
  color: #666;
  border: 2rpx solid #ddd;
}

.generated-list {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.audio-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #eee;
  transition: all 0.3s;
}

.audio-item:active {
  background: #f9f9f9;
}

.audio-item:last-child {
  border-bottom: none;
}

.audio-info {
  flex: 1;
  overflow: hidden;
}

.audio-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audio-prompt {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audio-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.audio-action {
  margin-left: 20rpx;
}

.play-icon {
  font-size: 40rpx;
}

.empty-state {
  background: white;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  display: block;
}

.empty-text {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.tips {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.tip-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tip-item {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  padding-left: 20rpx;
  position: relative;
}

.tip-item::before {
  content: "•";
  position: absolute;
  left: 0;
  color: #f5576c;
}