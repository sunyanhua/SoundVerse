/* 首页样式 */
.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
}

/* 顶部横幅 */
.banner {
  position: relative;
  height: 320rpx;
  overflow: hidden;
  border-radius: 0 0 24rpx 24rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-content {
  position: absolute;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  color: #fff;
}

.banner-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 快速入口 */
.quick-actions {
  background: #fff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-grid {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s;
}

.action-item:active .action-icon {
  transform: scale(0.95);
}

.chat-icon {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
}

.generate-icon {
  background: linear-gradient(135deg, #4ECDC4, #6EE7E7);
  color: #fff;
}

.upload-icon {
  background: linear-gradient(135deg, #45B7D1, #6CC3D5);
  color: #fff;
}

.profile-icon {
  background: linear-gradient(135deg, #96CEB4, #B0D7C5);
  color: #fff;
}

.action-text {
  font-size: 28rpx;
  color: #333;
  margin-top: 8rpx;
}

/* 分区样式 */
.section {
  background: #fff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 28rpx;
  color: #999;
}

.section-more:active {
  color: #FF6B6B;
}

/* 推荐音频滚动 */
.recommended-scroll {
  white-space: nowrap;
}

.recommended-list {
  display: inline-flex;
}

.recommended-item {
  width: 280rpx;
  margin-right: 24rpx;
  display: inline-block;
  background: #f8f9fa;
  border-radius: 16rpx;
  overflow: hidden;
  transition: transform 0.3s;
}

.recommended-item:active {
  transform: scale(0.98);
}

.recommended-item:last-child {
  margin-right: 0;
}

.audio-cover {
  width: 100%;
  height: 280rpx;
}

.audio-info {
  padding: 24rpx;
}

.audio-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.audio-duration {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.audio-tags {
  display: block;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  color: #666;
  background: #eee;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 功能说明 */
.features {
  margin-top: 16rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #ccc;
  margin-bottom: 32rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.refresh-btn {
  background: #FF6B6B;
  color: #fff;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}

.refresh-btn:active {
  background: #E55A5A;
}