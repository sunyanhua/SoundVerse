/* 首页样式 */
.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
}

/* 顶部横幅 */
.banner {
  position: relative;
  height: 320rpx;
  overflow: hidden;
  border-radius: 0 0 24rpx 24rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-content {
  position: absolute;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  color: #fff;
}

.banner-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 快速入口 */
.quick-actions {
  background: #fff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-grid {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s;
}

.action-item:active .action-icon {
  transform: scale(0.95);
}

.chat-icon {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
}

.generate-icon {
  background: linear-gradient(135deg, #4ECDC4, #6EE7E7);
  color: #fff;
}

.upload-icon {
  background: linear-gradient(135deg, #45B7D1, #6CC3D5);
  color: #fff;
}

.profile-icon {
  background: linear-gradient(135deg, #96CEB4, #B0D7C5);
  color: #fff;
}

.action-text {
  font-size: 28rpx;
  color: #333;
  margin-top: 8rpx;
}

/* 分区样式 */
.section {
  background: #fff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 28rpx;
  color: #999;
}

.section-more:active {
  color: #FF6B6B;
}

/* 推荐音频滚动 */
.recommended-scroll {
  white-space: nowrap;
}

.recommended-list {
  display: inline-flex;
}

.recommended-item {
  width: 280rpx;
  margin-right: 24rpx;
  display: inline-block;
  background: #f8f9fa;
  border-radius: 16rpx;
  overflow: hidden;
  transition: transform 0.3s;
}

.recommended-item:active {
  transform: scale(0.98);
}

.recommended-item:last-child {
  margin-right: 0;
}

.audio-cover {
  width: 100%;
  height: 280rpx;
}

.audio-info {
  padding: 24rpx;
}

.audio-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.audio-duration {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.audio-tags {
  display: block;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  color: #666;
  background: #eee;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 功能说明 */
.features {
  margin-top: 16rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #ccc;
  margin-bottom: 32rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.refresh-btn {
  background: #FF6B6B;
  color: #fff;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}

.refresh-btn:active {
  background: #E55A5A;
}

/* 音频预览弹窗样式 */
.audio-preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.preview-content {
  position: relative;
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 10000;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.preview-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0f0f0;
  color: #999;
  font-size: 36rpx;
  line-height: 60rpx;
  text-align: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.close-btn:active {
  background: #e0e0e0;
}

.preview-player {
  padding: 32rpx;
}

.preview-tags {
  padding: 0 32rpx 32rpx;
  border-top: 2rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.tags-label {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.preview-tags .tag {
  display: inline-block;
  font-size: 24rpx;
  color: #666;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

/* PC端满屏展示样式 */
@media (min-width: 768px) {
  /* 页面容器居中，限制最大宽度 */
  .page-container {
    max-width: 1200rpx;
    margin: 0 auto;
  }

  /* 顶部横幅 - 增加高度和字体大小 */
  .banner {
    height: 400rpx;
    border-radius: 0 0 32rpx 32rpx;
  }

  .banner-title {
    font-size: 56rpx;
  }

  .banner-subtitle {
    font-size: 36rpx;
  }

  /* 快速入口 - 增加间距和图标大小 */
  .quick-actions {
    margin: 40rpx 24rpx;
    padding: 40rpx 0;
  }

  .action-icon {
    width: 160rpx;
    height: 160rpx;
    font-size: 80rpx;
  }

  .action-text {
    font-size: 32rpx;
  }

  /* 分区样式 - 增加间距 */
  .section {
    margin: 40rpx 24rpx;
    padding: 40rpx;
  }

  .section-title {
    font-size: 44rpx;
  }

  .section-more {
    font-size: 32rpx;
  }

  /* 推荐音频 - 增加项宽度 */
  .recommended-item {
    width: 320rpx;
  }

  .audio-cover {
    height: 320rpx;
  }

  .audio-title {
    font-size: 36rpx;
  }

  .audio-duration {
    font-size: 30rpx;
  }

  .tag {
    font-size: 26rpx;
    padding: 6rpx 16rpx;
  }

  /* 功能说明 - 增加图标和字体大小 */
  .feature-icon {
    font-size: 56rpx;
  }

  .feature-title {
    font-size: 36rpx;
  }

  .feature-desc {
    font-size: 32rpx;
  }

  /* 音频预览弹窗 - 增加最大宽度 */
  .preview-content {
    max-width: 800rpx;
    width: 70%;
  }
}

