/* 全局样式 */
page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: #333;
  line-height: 1.5;
}

/* 容器类 */
.container {
  padding: 16rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin: 16rpx 0;
  padding: 24rpx;
}

/* 按钮样式 */
.btn {
  border-radius: 8rpx;
  padding: 20rpx 32rpx;
  font-size: 16px;
  text-align: center;
  transition: all 0.3s;
}

.btn-primary {
  background: #FF6B6B;
  color: #fff;
}

.btn-primary:active {
  background: #E55A5A;
}

.btn-secondary {
  background: #f0f0f0;
  color: #333;
}

.btn-secondary:active {
  background: #e0e0e0;
}

.btn-disabled {
  background: #ddd;
  color: #999;
  pointer-events: none;
}

/* 输入框样式 */
.input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 16px;
  background: #fff;
}

.input:focus {
  border-color: #FF6B6B;
  outline: none;
}

/* 文本样式 */
.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-primary {
  color: #FF6B6B;
}

.text-secondary {
  color: #999;
}

.text-success {
  color: #52c41a;
}

.text-warning {
  color: #faad14;
}

.text-error {
  color: #ff4d4f;
}

/* 间距工具类 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }

.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }

.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: 16rpx; }
.ml-24 { margin-left: 24rpx; }
.ml-32 { margin-left: 32rpx; }

.mr-8 { margin-right: 8rpx; }
.mr-16 { margin-right: 16rpx; }
.mr-24 { margin-right: 24rpx; }
.mr-32 { margin-right: 32rpx; }

.p-8 { padding: 8rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* 布局类 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
}

.flex-around {
  justify-content: space-around;
}

.align-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading .loading-text {
  margin-left: 16rpx;
  color: #999;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

.empty .empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  color: #ccc;
}

/* 音频播放器样式 */
.audio-player {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx 0;
}