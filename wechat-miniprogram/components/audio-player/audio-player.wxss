/* 音频播放器组件样式 */
.audio-player {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  margin: 24rpx 0;
}

/* 播放器头部 */
.player-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.audio-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.audio-duration {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

/* 播放器控制区域 */
.player-controls {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FF6B6B;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: none;
  padding: 0;
  flex-shrink: 0;
}

.control-btn.playing {
  background: #E55A5A;
}

.control-btn:active {
  opacity: 0.8;
}

.btn-icon {
  font-size: 40rpx;
  color: #fff;
}

.progress-slider {
  flex: 1;
  margin-right: 24rpx;
}

.time-display {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  min-width: 120rpx;
  text-align: right;
}

.current-time {
  color: #FF6B6B;
  font-weight: bold;
}

/* 播放器操作按钮 */
.player-actions {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
  padding-top: 24rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  flex: 1;
}

.action-btn:active {
  opacity: 0.7;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 错误提示 */
.error-message {
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.error-message text {
  color: #ff4d4f;
  font-size: 26rpx;
  flex: 1;
  margin-right: 16rpx;
}

.retry-btn {
  background: #ff4d4f;
  color: #fff;
  border-radius: 6rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border: none;
}

.retry-btn:active {
  background: #d9363e;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 28rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .audio-player {
    padding: 24rpx;
  }

  .audio-title {
    font-size: 32rpx;
  }

  .action-icon {
    font-size: 40rpx;
  }
}