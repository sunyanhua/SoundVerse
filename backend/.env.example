# 应用基础配置
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7天

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# 数据库配置
DATABASE_URL=mysql://soundverse:password@localhost:3306/soundverse
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# 阿里云配置
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_REGION_ID=cn-hangzhou

# 阿里云智能语音交互 (ASR/TTS)
ALIYUN_ASR_APP_KEY=your-asr-app-key
ALIYUN_TTS_APP_KEY=your-tts-app-key

# 阿里云自然语言处理 (NLP)
ALIYUN_NLP_ACCESS_KEY_ID=your-nlp-access-key-id
ALIYUN_NLP_ACCESS_KEY_SECRET=your-nlp-access-key-secret

# 对象存储 OSS 配置
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=ai-sun-vbegin-com-cn
OSS_PREFIX=audio/

# 百炼平台 (DashScope/Bailian) 配置
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# DashVector 向量检索服务配置
DASHVECTOR_ENDPOINT=your-dashvector-endpoint
DASHVECTOR_API_KEY=your-dashvector-api-key
DASHVECTOR_NAMESPACE=soundverse
DASHVECTOR_COLLECTION=audio_segments
DASHVECTOR_COLLECTION_DIMENSION=1536

# 微信小程序配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 音频处理配置
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_BITRATE=64k
MIN_AUDIO_DURATION=1.0
MAX_AUDIO_DURATION=300.0

# 音频分割配置
MIN_SILENCE_LEN=500
SILENCE_THRESH=-40
KEEP_SILENCE=200
MIN_SEGMENT_DURATION=2.0
MAX_SEGMENT_DURATION=30.0

# 语义搜索配置
VECTOR_DIMENSION=512
FAISS_INDEX_PATH=data/faiss_index.bin
SEARCH_TOP_K=5
SIMILARITY_THRESHOLD=0.6

# 缓存配置
CACHE_TTL=3600
USER_CACHE_TTL=1800
AUDIO_CACHE_TTL=86400

# 速率限制
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/soundverse.log
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2